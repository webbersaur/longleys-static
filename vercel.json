{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "_comment": "www -> apex canonicalization is configured at the Vercel domain level (Domains > www.longleysct.com > redirect to longleysct.com, 308), not here. A host-based redirect in this file does not fire, because domain-level redirects run before vercel.json routing.",
  "redirects": [
    {
      "source": "/off-premise-catering-2/",
      "destination": "/off-premise-catering/",
      "permanent": true
    },
    {
      "source": "/about-us/",
      "destination": "/why-locals-love-longleys/",
      "permanent": true
    },
    {
      "source": "/did-somebody-say-homemade/",
      "destination": "/menu/",
      "permanent": true
    },
    {
      "source": "/happy/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/not-happy/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/thank-you/",
      "destination": "/",
      "permanent": true
    }
  ]
}
